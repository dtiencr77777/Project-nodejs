extends ../../layouts/default.pug

block main
  h1 Thông tin tài khoản của tôi
  p Đây là trang thông tin tài khoản của bạn.
  h1(class="mt-4") Thông tin cá nhân
  if(user.avatar)
    img(
      src=user.avatar
      alt=user.fullName
      width="100 px"
      height="auto"
    )
  if(user.fullName)
    p Họ tên: <b>#{user.fullName}</b>


  if(user.email)
    p Email: <b>#{user.email}</b>
  if(user.phone)
    p Số điện thoại: <b>#{user.phone}</b>

  p
    span Trạng thái:
      if(user.status === "active")
        a(
          href="javascript:;"
          class="bagde badge-success"
          data-status="active"
        ) hoạt động
      else
        a(
          href="javascript:;"
          class="bagde badge-danger"
          data-status="inactive"
        ) không hoạt động
  if(user.role)
    p Phân quyền: #{user.role.title}

  a(
    href=`${prefixAdmin}/my-account/edit`
    class="btn btn-primary mt-3"
  ) Sửa thông tin cá nhân

