extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main

  h1(class="mb-4") Cập nhật thông tin cá nhân

  +alert-success(5000)
  +alert-error(5000)

  form(
    action=`${prefixAdmin}/my-account/edit?_method=PATCH`
    method="POST"
    enctype="multipart/form-data"
  )
    div(class="form-group")
      label(for="fullName") Họ tên *
      input(
        type="text"
        class="form-control"
        id="fullName"
        name="fullName"
        required
        value=user.fullName
      )
    div(class="form-group")
      label(for="email") Email *
      input(
        type="email"
        class="form-control"
        id="email"
        name="email"
        required
        value=user.email
      )
    div(class="password")
      label(for="password") Mật khẩu mới
      input(
        type="password"
        class="form-control"
        id="password"
        name="password"
        placeholder="Để trống nếu không muốn thay đổi mật khẩu"
      )
    div(class="form-group")
      label(for="phone") Số điện thoại
      input(  
        type="text"
        class="form-control"
        id="phone"
        name="phone"
        value=user.phone
      )
    div(
      class="form-group"
      upload-image
    )
      label(for="avatar") Ảnh đại diện
      input(
        type="file"
        class="form-control-file"
        id="avatar"
        name="avatar"
        accept="image/*"
        upload-image-input
      )
      img(
        src=user.avatar
        alt="Ảnh đại diện"
        class="img-thumbnail mt-2"
        style="max-width: 150px;"
        upload-image-preview
      )
    button(type="submit" class="btn btn-primary") Cập nhật