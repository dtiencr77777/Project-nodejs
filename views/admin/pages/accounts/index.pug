extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  if(role.permissions.includes('accounts_view'))
    h1 Trang Quản lý tài khoản Admin
    p Đây là trang quản lý tài khoản Admin.
    +alert-success(5000)

    .card.mb-3
      .card-header Danh Sách Nhóm Quyền
      .card-body
        .row 
          .col-8
          if(role.permissions.includes('accounts-create'))
            .col-4.text-right
              a(
                href=`${prefixAdmin}/accounts/create`
                class="btn btn-outline-success"
              ) + Thêm mới

        table(
          class="table table-hover table-sm"
        )
          thead
            tr
              th(scope="col") STT
              th(scope="col") Avartar
              th(scope="col") Họ Tên
              th(scope="col") Phân quyền 
              th(scope="col") Email
              th(scope="col") Số điện thoại
              th(scope="col") Trạng thái
              th(scope="col") Hành động

          tbody
            each item, index in records
              tr
                td(scope="row") #{index + 1}
                td
                  img(
                    src=item.avatar
                    alt=item.fullName
                    width="50 px"
                    height="auto"
                    upload-image-input

              )
                td #{item.fullName}
                td #{item.role.title}
                td #{item.email}
                td #{item.phone}
                td
                  if(item.status === "active")
                    a(
                      href="javascript:;"
                      class="bagde badge-success"
                      data-status="active"
                    ) hoạt động
                  else
                    a(
                      href="javascript:;"
                      class="bagde badge-danger"
                      data-status="inactive"
                    ) Dừng hoạt động


                td
                  a.btn.btn-info.btn-sm(
                    href=``
                    ) Chi Tiết
                  if(role.permissions.includes('accounts-edit'))
                    a.btn.btn-warning.btn-sm(
                      href=`/admin/accounts/edit/${item.id}`
                      ) Sửa
                  if(role.permissions.includes('accounts-delete'))
                    a.btn.btn-danger.btn-sm.ml-1(
                      href="#"
                      data-id=item.id
                      button-delete
                      ) Xóa