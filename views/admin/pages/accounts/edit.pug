extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  h1(class="mb-4") Edit tài khoản
  +alert-error(5000)

  form(
    action = `${prefixAdmin}/accounts/edit/${data.id}?_method=PATCH`
    method="POST"
    enctype="multipart/form-data"
  )
    div(class="form-group")
      labe(for="fullName") Họ Tên *
      input(
        type="text"
        class="form-control"
        id = "fullName"
        name="fullName"
        value=data.fullName
      )
    div(class="form-group")
      label(for="email") Email *
      input(
        type="text"
        class="form-control"
        id = "email"
        name="email"
        value=data.email)


    div(class="form-group")
      labell(for="password") Mật khẩu *
      input(
        type="password"
        class="form-control"
        id = "password"
        name="password"
      )

    div(class="form-group")
      label(for="phone") Số điện thoại *
      input(
        type="number"
        class="form-control"
        id = "phone"
        name="phone"
        value=data.phone)

      div(
        class="form-group"
        uploade-image
        )
        label(for="avatar") Avatar 
        input(
          type="file"
          class="form-control-file"
          id = "avatar"
          name="avatar"
          accept="image/*"
          upload-image-input
        )
        img(
          src=data.avatar
          class="image-preview mt-2"
          upload-image-preview
        )


    div(class="form-group")
      label(for="rode_id") Phân quyền
      select(name="role_id" id="role_id" class="form-control")
        option(disabled) -- chọn quyền --
        each item in roles
          option(
            value=item.id
            selected=(item.id ===data.role_id ? true :false)
          ) #{item.title}


    div(class="form-group form-check form-check-inline")
      input(
        type="radio"
        class="form-check-input"
        id="statusActive"
        name="status"
        value="active"
        checked=(data.status === "active" ? true :false)
      )
      label(for="statusActive" class="form-checki-label") Hoạt động


    div(class="form-group form-check form-check-inline")
      input(
        type="radio"
        class="form-check-input"
        id="statusInactive"
        name="status"
        value="inactive"
        checked=(data.status === "inactive" ? true :false)
      )
      label(for="statusInactive" class="form-checki-label") Không hoạt động

    div(class="form-group")
      button(
        type="submit"
        class="btn btn-primary"
      ) Lưu
