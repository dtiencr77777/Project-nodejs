extends ../../layouts/default.pug
block main

  .container.my-3
    .row
      .col-12
        if (product.title)
          h1(class="mb-4") #{product.title}
        if(product.category)
          div(class="mb-4")
            span Danh mục: 
            a(href=`/products/${product.category.slug}`) #{product.category.title}
        if (product.price)
          div(class="mb-4") Giá: <b>#{product.price}$</b>

        if (product.discountPercentage)
          div(class="mb-4") Giảm giá: <b>#{product.discountPercentage}%</b>

        if (product.stock)
          div(class="mb-4") Còn lại: <b>#{product.stock}</b>

        if (product.thumbnail)
          div(class="mb-4")
            img(
              src=product.thumbnail
              style="width: 100px"
            )
        if(product.status)
          div(class="mb-4")
            span Trạng thái 
            if(product.status==="active")
              span(class="badge badge-success") Hoạt động
            else 
              span(class="badge badge-danger") Dừng hoạt động


        if(product.position)
          div(class="mb-4") Vị trí: <b>#{product.position}</b>

        form(
          action=`/cart/add/${product._id}`
          method="POST"
        )
          input(
            type="number"
            name="quantity"
            value="1"
            min="1"
            class="form-control mb-2"
            max = product.stock
          ) 
          button(
            type="submit"
            class="btn btn-primary"
          ) Thêm vào giỏ hàng
        if(product.description)
          div(class="mb-4") !{product.description}


